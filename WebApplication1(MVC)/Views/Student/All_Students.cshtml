@model IEnumerable<WebApplication1_MVC_.DTOs.StudentResponseDTO>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-people-fill me-2"></i>قائمة الطلاب</h2>
        <a class="btn btn-primary rounded-pill px-4 shadow-sm" asp-action="Add_Student">
            <i class="bi bi-person-plus-fill"></i> إضافة طالب جديد
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0 rounded-4">
                    <div class="card-body text-center p-4">
                        <!-- أيقونة الطالب -->
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-person-fill h1 mb-0"></i>
                        </div>
                        
                        <!-- بيانات الطالب -->
                        <h5 class="card-title fw-bold mb-1">@item.StudentName</h5>
                        <p class="text-muted small mb-2">@item.Student_Email <i class="bi bi-envelope ms-1"></i></p>
                        
                        <div class="d-flex justify-content-center gap-3 mb-3">
                            <span class="badge bg-light text-dark border rounded-pill px-3">
                                <i class="bi bi-calendar-event me-1"></i> العمر: @item.StudentAge
                            </span>
                            <span class="badge bg-light text-dark border rounded-pill px-3">
                                <i class="bi bi-hash me-1"></i> كود: @item.StudentId
                            </span>
                        </div>
                    </div>
                    
                    <!-- أزرار التحكم -->
                    <div class="card-footer bg-white border-0 d-flex justify-content-center gap-2 pb-4">
                        <a class="btn btn-sm btn-info text-white px-3 rounded-3 shadow-sm"
                           asp-action="Info_Student"
                           asp-route-id="@item.StudentId">تفاصيل</a>

                        <a class="btn btn-sm btn-primary px-3 rounded-3 shadow-sm"
                           asp-action="Update_Student"
                           asp-route-id="@item.StudentId">تعديل</a>

                        <a class="btn btn-sm btn-danger px-3 rounded-3 shadow-sm"
                           asp-action="Delete_Student"
                           asp-route-id="@item.StudentId">حذف</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>