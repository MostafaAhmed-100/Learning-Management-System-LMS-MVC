@model WebApplication1_MVC_.DTOs.StudentResponseDTO
<div class="card">
    <h3><strong>Are You Sure you want to delete this student</strong></h3>
    <div class="card-body">
        <h5 class="card-title"> @Model.StudentName</h5>
        <p>His Id Is : @Model.StudentId</p>
    </div>
    <div class="card-footer">
        <form asp-action="Delete_Student" asp-action="Delete_Student" method="post">
            <input type="hidden" name="id" value="@Model.StudentId" />
            <input type="submit" value="delete" class="btn btn-danger" />
            <a asp-action="All_Students" class="btn btn-secondary px-4">Back to List</a>
        </form>
    </div>
</div>