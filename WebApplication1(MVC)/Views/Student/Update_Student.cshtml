@model StudentRequestDto

<div class="container mt-4">
    <div class="card col-md-6 mx-auto shadow border-0 rounded-4">
        <div class="card-header bg-dark text-white py-3 rounded-top-4">
            <h4 class="mb-0 text-center"><i class="bi bi-pencil-square me-2"></i>تعديل بيانات الطالب</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Update_Student" method="post">
                <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />
                
                <div class="mb-3">
                    <label class="form-label fw-bold">اسم الطالب</label>
                    <input asp-for="StudentName" class="form-control rounded-3 shadow-sm" />
                    <span asp-validation-for="StudentName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">البريد الإلكتروني</label>
                    <input asp-for="StudentEmail" class="form-control rounded-3 shadow-sm" />
                    <span asp-validation-for="StudentEmail" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">العمر</label>
                    <input asp-for="StudentAge" class="form-control rounded-3 shadow-sm" />
                    <span asp-validation-for="StudentAge" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">كلمة المرور</label>
                    <input asp-for="StudentPassword" type="password" class="form-control rounded-3 shadow-sm" />
                    <span asp-validation-for="StudentPassword" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-dark btn-lg rounded-pill shadow fw-bold">حفظ التغييرات</button>
                    <a asp-action="All_Students" class="btn btn-light rounded-pill border">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>