@model ErrorViewModel
@{
    ViewData["Title"] = "Oops! Something went wrong";
}

<div class="container text-center" style="margin-top: 50px;">
    <div class="display-1 text-danger">
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>

    <h1 class="text-danger mt-3">عذراً، حدث خطأ ما!</h1>
    
    <div class="row justify-content-center mt-4">
        <div class="col-md-8">
            <div class="card border-danger mb-3">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">تفاصيل الخطأ</h5>
                </div>
                <div class="card-body">
                    <p class="card-text fs-5 text-dark">
                        @if (ViewData["ErrorMessage"] != null)
                        {
                            @ViewData["ErrorMessage"]
                        }
                        else
                        {
                            <span>حدث خطأ غير متوقع في النظام، يرجى المحاولة لاحقاً.</span>
                        }
                    </p>
                </div>
            </div>

            <div class="mt-4">
                <p class="text-muted">إذا استمرت المشكلة، يرجى التواصل مع الدعم الفني.</p>
                <a href="/" class="btn btn-primary px-4">العودة للرئيسية</a>
            </div>
        </div>
    </div>
</div>