@model ErrorViewModel
<div class="container text-center py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="display-1 text-danger mb-4">
                <i class="bi bi-exclamation-octagon-fill"></i>
            </div>
            <h1 class="fw-bold">حدث خطأ غير متوقع</h1>
            <p class="text-muted fs-5 mb-4">نعتذر عن الإزعاج، يبدو أن هناك مشكلة فنية حدثت في النظام.</p>
            
            <div class="card border-0 bg-light p-4 mb-4 text-start">
                <h6 class="fw-bold border-bottom pb-2 mb-3">تفاصيل تقنية:</h6>
                <code>
                    @if (ViewData["ErrorMessage"] != null)
                    {
                        @ViewData["ErrorMessage"]
                    }
                    else
                    {

                        <span>Internal System Error (Status 500)</span>
                    }
                </code>
            </div>
            
            <a href="/" class="btn btn-primary btn-lg rounded-pill px-5 shadow">العودة للرئيسية</a>
        </div>
    </div>
</div>