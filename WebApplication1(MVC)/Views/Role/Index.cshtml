@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityRole>
<div class="container mt-4">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0">إضافة دور جديد</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">اسم الدور</label>
                            <input name="roleName" class="form-control rounded-3" placeholder="مثلاً: Admin" required />
                        </div>
                        <button type="submit" class="btn btn-success w-100 rounded-pill shadow-sm">حفظ الدور</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0">الأدوار الحالية</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th>اسم الدور</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in Model)
                            {
                                <tr>
                                    <td class="ps-4 small text-muted">@role.Id</td>
                                    <td><span class="badge rounded-pill bg-info text-dark px-3">@role.Name</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>