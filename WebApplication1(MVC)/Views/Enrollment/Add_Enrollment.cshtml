@model WebApplication1_MVC_.DTOs.Request_DTOs.EnrollmentRequestDto

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white py-4 text-center rounded-top-4">
                    <h3 class="mb-0 fw-bold">
                        <i class="bi bi-journal-plus me-2"></i>
                        @(User.IsInRole("Admin") ? "تسجيل طالب في كورس" : "اشتراك في كورس جديد")
                    </h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Add_Enrollment" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 small"></div>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="mb-4">
                                <label class="form-label fw-bold text-dark"><i class="bi bi-person me-1"></i>اختر الطالب</label>
                                <select asp-for="StudentId" class="form-select form-select-lg shadow-sm border-0 bg-light"
                                        asp-items="@(new SelectList(ViewBag.Students, "StudentId", "StudentName"))">
                                    <option value="">-- اضغط للاختيار --</option>
                                </select>
                                <span asp-validation-for="StudentId" class="text-danger small"></span>
                            </div>
                        }
                        else
                        {
                            <input type="hidden" asp-for="StudentId" value="0" />
                            <div class="alert alert-info border-0 rounded-3 mb-4">
                                <i class="bi bi-info-circle-fill me-2"></i>
                                سيتم تسجيل الكورس باسمك مباشرة: <strong>@User.Identity.Name</strong>
                            </div>
                        }

                        <div class="mb-5">
                            <label class="form-label fw-bold text-dark"><i class="bi bi-book me-1"></i>اختر الكورس</label>
                            <select asp-for="CourseId" class="form-select form-select-lg shadow-sm border-0 bg-light"
                                    asp-items="@(new SelectList(ViewBag.Courses, "CourseId", "CourseTitle"))">
                                <option value="">-- اختر الكورس المطلوب --</option>
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow py-3 fw-bold">
                                <i class="bi bi-check2-circle me-1"></i> إتمام التسجيل
                            </button>
                            <a asp-action="All_Enrollment" class="btn btn-outline-secondary rounded-pill py-2 mt-2">عودة للقائمة</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>