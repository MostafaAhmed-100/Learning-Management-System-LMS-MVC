@model IEnumerable<WebApplication1_MVC_.DTOs.EnrollmentResponseDTO>

@{
    ViewData["Title"] = "Enrollments List";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>All Enrollments</h1>
    <a asp-action="Add_Enrollment" class="btn btn-success">Add New Enrollment</a>
    <a class="btn btn-primary" asp-controller="Student" asp-action="All_Students">All Students</a>
</div>

<table class="table table-striped table-hover border">
    <thead class="table-dark">
        <tr>
            <th>Student Name</th>
            <th>Course Name</th>
            <th>Enrollment Date</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StudentName</td>
                <td>@item.CourseTitle</td>
                <td>@item.EnrollmentDate.ToShortDateString()</td>
                <td class="text-center">
                    <form asp-action="Delete_Enrollment" method="post" onsubmit="return confirm('Are you sure?')">
                        <input type="hidden" name="studentId" value="@item.StudentId" />
                        <input type="hidden" name="courseId" value="@item.CourseId" />
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>