@model WebApplication1_MVC_.DTOs.InstructorResponseDTO

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 text-center p-4 rounded-4 mb-4">
                <div class="bg-primary text-white rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3" style="width: 100px; height: 100px;">
                    <i class="bi bi-person-bounding-box h1 mb-0"></i>
                </div>
                <h3 class="fw-bold">@Model.InstructorName</h3>
                <p class="text-muted">@Model.InstructorEmail</p>
                <hr />
                <div class="text-start">
                    <p><strong><i class="bi bi-telephone me-2"></i>الهاتف:</strong> @Model.InstructorPhone</p>
                    <p><strong><i class="bi bi-info-circle me-2"></i>النبذة:</strong> @Model.InstructorBio</p>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-book me-2 text-primary"></i>الكورسات التي يدرسها</h5>
                </div>
                <div class="card-body">
                    @if (Model.Coures != null && Model.Coures.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var course in Model.Coures)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                                    <span><i class="bi bi-check2-circle text-success me-2"></i>@course</span>
                                    <span class="badge bg-light text-primary rounded-pill">نشط</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-light text-center py-4 border-0">
                            <i class="bi bi-folder-x h1 text-muted d-block"></i>
                            لم يتم تعيين كورسات لهذا المحاضر بعد.
                        </div>
                    }
                </div>
                <div class="card-footer bg-light border-0 d-flex justify-content-end gap-2 py-3">
                    <a asp-action="All_Instructors" class="btn btn-secondary px-4 rounded-pill">عودة</a>
                    <a asp-action="Update_Instructor" asp-route-id="@Model.InstracrorId" class="btn btn-primary px-4 rounded-pill">تعديل البيانات</a>
                </div>
            </div>
        </div>
    </div>
</div>