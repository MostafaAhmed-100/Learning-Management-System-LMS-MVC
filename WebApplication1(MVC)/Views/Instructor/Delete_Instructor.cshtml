@model WebApplication1_MVC_.DTOs.InstructorResponseDTO

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4 overflow-hidden">
                <div class="bg-danger p-4 text-center text-white">
                    <i class="bi bi-exclamation-triangle h1"></i>
                    <h3 class="fw-bold">تأكيد الحذف</h3>
                </div>
                <div class="card-body p-4 text-center">
                    <p class="fs-5 mb-4 text-muted">هل أنت متأكد من رغبتك في حذف المحاضر:</p>
                    <h2 class="text-dark fw-bold mb-3">@Model.InstructorName</h2>
                    <div class="alert alert-warning border-0 rounded-3 small">
                        <i class="bi bi-info-circle me-1"></i> سيتم حذف كافة سجلات هذا المحاضر المرتبطة بالكورسات.
                    </div>
                </div>
                <div class="card-footer bg-light p-3 border-0 d-flex gap-2">
                    <form asp-action="Delete_Instructor" method="post" class="w-100 d-flex gap-2">
                        <input type="hidden" name="id" value="@Model.InstracrorId" />
                        <button type="submit" class="btn btn-danger w-50 rounded-pill py-2 fw-bold">نعم، احذف</button>
                        <a asp-action="All_Instructors" class="btn btn-outline-secondary w-50 rounded-pill py-2 fw-bold">إلغاء</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>