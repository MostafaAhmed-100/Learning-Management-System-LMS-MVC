@model IEnumerable<WebApplication1_MVC_.DTOs.InstructorResponseDTO>
<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-person-workspace me-2"></i>هيئة التدريس</h2>
        <a class="btn btn-primary rounded-pill shadow-sm" asp-action="Add_Instructor">
            <i class="bi bi-person-plus-fill"></i> إضافة محاضر جديد
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body text-center">
                        <div class="bg-primary text-white rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                            <i class="bi bi-person h2 mb-0"></i>
                        </div>
                        <h5 class="card-title fw-bold">@item.InstructorName</h5>
                        <p class="text-muted small mb-1"><i class="bi bi-envelope"></i> @item.InstructorEmail</p>
                        <p class="text-muted small"><i class="bi bi-phone"></i> @item.InstructorPhone</p>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex justify-content-center gap-2 pb-4">
                        <a class="btn btn-sm btn-info text-white px-3 shadow-sm" asp-action="Info_Instructor" asp-route-id="@item.InstracrorId">تفاصيل</a>
                        <a class="btn btn-sm btn-primary px-3 shadow-sm" asp-action="Update_Instructor" asp-route-id="@item.InstracrorId">تعديل</a>
                        <a class="btn btn-sm btn-danger px-3 shadow-sm" asp-action="Delete_Instructor" asp-route-id="@item.InstracrorId">حذف</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>