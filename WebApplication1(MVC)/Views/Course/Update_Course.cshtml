@model WebApplication1_MVC_.DTOs.CourseResponseDTO

<div class="container mt-4">
    <div class="card col-md-8 mx-auto shadow-sm border-0 rounded-4">
        <div class="card-header bg-dark text-white py-3">
            <h4 class="mb-0 text-center"><i class="bi bi-pencil-square me-2"></i>تحديث بيانات الكورس</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Update_Course" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">اسم الكورس</label>
                        <input asp-for="CourseTitle" class="form-control" />
                        <span asp-validation-for="CourseTitle" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">السعر</label>
                        <input asp-for="CoursePrice" type="number" class="form-control" />
                        <span asp-validation-for="CoursePrice" class="text-danger"></span>
                    </div>
                    <div class="col-12 mb-3">
                        <label class="form-label fw-bold">الوصف</label>
                        <textarea asp-for="CourseDescription" rows="4" class="form-control"></textarea>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-dark px-5 rounded-pill shadow">حفظ التحديثات</button>
                    <a asp-action="All_Courses" class="btn btn-outline-secondary px-5 rounded-pill">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>